{
  "name": "divinitycrm-backend",
  "version": "1.0.0",
  "description": "Divinity CRM Platform API — Neon + Express + Clerk",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/scripts/env-validator.js && node src/index.js",
