# Neon connection string (get from neon.tech dashboard)
DATABASE_URL=postgresql://neondb_owner:***@ep-divine-term-adcheii9-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT signing secret (required in production)
JWT_SECRET=replace-with-a-long-random-string

# Clerk (get from clerk.com dashboard)
CLERK_SECRET_KEY=sk_...
